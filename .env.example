# Clerk Authentication
# Get your publishable key from https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# API Configuration
# FastAPI AI Service — pipeline, analysis, questions, enhance, crucible
VITE_API_BASE_URL=http://localhost:8000/api/v1

# NestJS Backend — jobs CRUD, resumes, subscriptions, auth
VITE_BACKEND_URL=http://localhost:3000/api/v1

# Pipeline mode — enables real API calls to FastAPI pipeline endpoints
# Set to false only if developing frontend UI without a backend
VITE_PIPELINE_MODE=true

# Bypass Clerk auth for local development
VITE_BYPASS_AUTH=true

# Application Configuration
VITE_APP_NAME=Resu-ME AI
VITE_ENVIRONMENT=development

# Feature flags
VITE_DEMO_MODE=false

# Stripe (required for billing/checkout flows; optional for local UI dev)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_YEARLY=price_...
VITE_STRIPE_PRICE_KIT_MONTHLY=price_...
VITE_STRIPE_PRICE_KIT_YEARLY=price_...
VITE_STRIPE_PRICE_WORKSPACE_MONTHLY=price_...
VITE_STRIPE_PRICE_WORKSPACE_YEARLY=price_...

# Analytics (optional — leave empty to disable)
VITE_MIXPANEL_TOKEN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
