{
  "name": "resu-me-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:components": "vitest run --config vite.config.ts --project component",
    "test:components:watch": "vitest --config vite.config.ts --project component",
    "test:storybook": "vitest run --config vite.config.ts --project storybook",
    "test:all": "vitest run --config vite.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "deploy-storybook": "storybook build && cd storybook-static && vercel --prod"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.2",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.0.7",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-mcp": "^0.2.2",
    "@storybook/addon-onboarding": "^10.0.7",
    "@storybook/addon-vitest": "^10.0.7",
    "@storybook/react": "10.2.0",
    "@storybook/react-vite": "^10.0.7",
    "@stripe/stripe-js": "^8.7.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.8",
    "@vitest/coverage-v8": "^4.0.8",
    "autoprefixer": "^10.4.22",
    "chromatic": "^13.3.5",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.0.7",
    "jsdom": "^26.0.0",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "storybook": "^10.0.7",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.55.0",
    "@clerk/shared": "^3.44.0",
    "@clerk/types": "^4.101.14",
    "@fontsource/inter": "^5.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-form": "^1.23.8",
    "@tanstack/react-query": "^5.90.8",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/pm": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "dompurify": "^3.3.1",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "mixpanel-browser": "^2.73.0",
    "posthog-js": "^1.194.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^7.9.5"
  }
